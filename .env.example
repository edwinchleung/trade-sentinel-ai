# PostgreSQL (Docker Compose — default credentials)
# Host port 5433 avoids conflict if you already run Postgres on 5432
POSTGRES_PORT=5433
POSTGRES_USER=tradesentinel
POSTGRES_PASSWORD=tradesentinel
POSTGRES_DB=tradesentinel
DATABASE_URL=postgresql://tradesentinel:tradesentinel@localhost:5433/tradesentinel

# LLM (required for AI summaries) — use ONE profile below
# Hong Kong: direct OpenAI/Anthropic APIs are often blocked; OpenRouter is the default.

# --- OpenRouter (recommended) ---
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
# LLM_BASE_URL=https://openrouter.ai/api/v1

# --- Ollama (local, no API key) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL=llama3.2

# --- Alibaba DashScope (Qwen) ---
# LLM_PROVIDER=dashscope
# DASHSCOPE_API_KEY=
# LLM_MODEL=qwen-plus

# --- Legacy: direct OpenAI / Anthropic (if available in your region) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-3-5-haiku-20241022

# Optional: generic OpenAI-compatible endpoint (DeepSeek, SiliconFlow, etc.)
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional news & macro data
FINNHUB_API_KEY=
FRED_API_KEY=
NEWSAPI_KEY=
MACRO_NEWS_LIMIT=12
MACRO_TRADING_TIMEZONE=America/New_York
MACRO_VIX_ELEVATED_THRESHOLD=20

# SEC EDGAR (User-Agent required by SEC fair-access policy — use a real contact email)
SEC_USER_NAME=TradeSentinelAI
SEC_USER_EMAIL=you@yourdomain.com
# EdgarTools rate limit: NORMAL | CAUTION | CRAWL (CAUTION recommended with background jobs)
# EDGAR_ACCESS_MODE=CAUTION
# EDGAR_CURRENT_PAGE_SIZE=100
# EDGAR_FEED_MAX_ENTRIES=200
# EDGAR_REGISTRY_WARM_ENABLED=false
# EDGAR_ENABLED_FORMS=

# Watchlist digest / screener / smart-money scan cap (alphabetical first N tickers)
# DIGEST_MAX_TICKERS=20

# Market valuation screener cache TTL in minutes (S&P 500 preset default)
# MARKET_SCREENER_CACHE_MINUTES=60
# MARKET_SCREENER_UNIVERSE=sp500

# Background refresh (digest, screener, smart-money) — runs inside API on startup + interval
# BACKGROUND_JOBS_ENABLED=true
# Run digest/screener/smart-money warm in background after API is up (does not block HTTP)
# BACKGROUND_STARTUP_WARM=true
# WEBSOCKET_ENABLED=true
# BACKGROUND_REFRESH_INTERVAL_MINUTES=30
# BACKGROUND_SCAN_WORKERS=4
# BACKGROUND_WATCHLIST_DEBOUNCE_SECONDS=15
# YFINANCE_BATCH_CHUNK_SIZE=25
# YFINANCE_CHUNK_DELAY_SECONDS=1.0
# YFINANCE_QUIET_LOGS=true
# SEC_RETRY_MAX=3
# SEC_RETRY_BASE_SECONDS=2
# SEC_CIK_FAILURE_TTL_SECONDS=120
# SEC_REQUESTS_PER_SECOND=8
# SEC_REQUEST_MIN_INTERVAL_MS=120
# SEC_JOB_GAP_SECONDS=5
# SEC_SUBMISSIONS_CACHE_SECONDS=3600
# SEC_FAILURE_CACHE_SECONDS=120

# Fair-value assessment
# VALUATION_COMPOSITE_MODE=iqr
# VALUATION_COMPOSITE_MODE=weighted
# VALUATION_INCLUDE_DCF=true
# VALUATION_MOS_TECH_OVER=15
# VALUATION_MOS_TECH_UNDER=-15
# VALUATION_MOS_DEFENSIVE_OVER=8
# VALUATION_MOS_DEFENSIVE_UNDER=-8
# VALUATION_MOS_DEFAULT_OVER=10
# VALUATION_MOS_DEFAULT_UNDER=-10
# Graham-style buy discount vs fair mid (price must be this % below mid)
# VALUATION_MOS_BUY_THRESHOLD_PCT=25

CACHE_TTL_SECONDS=900
DIGEST_MAX_TICKERS=20
DIGEST_CONCURRENCY=3
SMART_MONEY_FEED_CACHE_MINUTES=30
# SMART_MONEY_FEED_DEFAULT_DAYS=1
# SMART_MONEY_FEED_MAX_RANGE_DAYS=30
SMART_MONEY_SCAN_CONCURRENCY=3
SMART_MONEY_OPTIONS_CACHE_MINUTES=60
SMART_MONEY_OPEN_MARKET_ONLY=true
SMART_MONEY_13F_CACHE_HOURS=24
SMART_MONEY_COT_CACHE_HOURS=168
SMART_MONEY_VOLUME_CACHE_MINUTES=60
SMART_MONEY_PROACTIVE_UNIVERSE=sp500
SMART_MONEY_SP500_CACHE_MINUTES=120
# Optional paid tier (not used in free implementation)
POLYGON_API_KEY=
# SEC bulk 13F / N-PORT hybrid storage (Parquet/CSV + SQLite/Postgres index)
SEC_BULK_13F_ENABLED=true
SEC_BULK_NPORT_ENABLED=true
SEC_BULK_NPORT_BACKGROUND_ENABLED=false
# Optional comma-separated fund CIKs; defaults to SPY/QQQ/ARKK/IWM/VTI map
SEC_BULK_NPORT_FUND_CIKS=
SEC_BULK_DATA_DIR=data/sec_bulk
SQUEEZEMETRICS_API_KEY=
UNUSUAL_WHALES_API_KEY=
CONGRESSIONAL_TRADES_API_KEY=
CONGRESSIONAL_TRADES_PROVIDER=capitol_trades
POLYGON_OPTIONS_TICKS_ENABLED=true
GEX_COMPUTE_ENABLED=true
DIX_FINRA_PROXY_ENABLED=true
OPTIONS_PC_BULLISH_MAX=0.70
OPTIONS_PC_FEAR_MIN=0.90
OPTIONS_VOL_OI_UNUSUAL=3.0
OPTIONS_VOL_OI_HIGH=5.0
OPTIONS_MIN_PREMIUM_USD=500000
CORS_ORIGINS=http://localhost:3000

# API host port (change if native uvicorn already uses 8000)
API_PORT=8000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
